  "devDependencies": {
    "@wordpress/scripts": "^28.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "block"
  ],
