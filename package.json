{
  "name": "wp-gutenberg-demo",
  "version": "1.0.0",
  "description": "Demo Gutenberg block with security and quality standards",
  "main": "build/index.js",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "lint:js": "wp-scripts lint-js",
